# OS / editor
Thumbs.db
Desktop.ini
.DS_Store
*.swp
.idea/
.vscode/
*.log

# PHP / Python cache
**/__pycache__/
*.pyc
*.pyo

# Local secrets (keep config.php tracked but never commit real env overrides)
.env
.env.*
!.env.example
config.local.php
**/config.local.php

# Runtime lead capture (may contain personal data)
website/admin/leads.json
website/config.local.php
website/data/leads.jsonl
website/data/leads.json

# Generated mass stubs (router virtual routes; regenerable via bin/*)
# Keep index.php and handcrafted landings tracked.
website/pages/keywords/*/
website/pages/keywords/*.php
!website/pages/keywords/index.php
website/pages/areas/*.php
!website/pages/areas/index.php
website/pages/manufacturers/*.php
!website/pages/manufacturers/index.php
website/pages/services/*.php
!website/pages/services/index.php
