# Icomply — clean extensionless URLs (XAMPP subfolder /icomply)
DirectoryIndex index.php index.html
Options -Indexes

ErrorDocument 404 /icomply/index-router.php

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /icomply/

    RewriteRule ^bin/ - [F,L]
    RewriteRule ^templates/ - [F,L]
    RewriteRule ^data/ - [F,L]
    RewriteRule ^config\.php$ - [F,L]
    RewriteRule ^config\.local\.php$ - [F,L]
    RewriteRule ^data/.*\.jsonl$ - [F,L]
    RewriteRule ^includes/ - [F,L]

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 301 strip .php from public URLs
    RewriteCond %{THE_REQUEST} \s/icomply/([^\s?]*)\.php[\s?] [NC]
    RewriteRule ^ %1 [R=301,L,NE]

    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L]

    RewriteRule ^ index-router.php [L,QSA]
</IfModule>

<IfModule mod_authz_core.c>
    <FilesMatch "^(?i)config(\.local)?\.php$">
        Require all denied
    </FilesMatch>
    <FilesMatch "(?i)\.jsonl$">
        Require all denied
    </FilesMatch>
</IfModule>
